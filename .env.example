# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_KEY=eyJhbGc...

# Direct Postgres connection (for bulk upserts via psycopg2)
# Find in Supabase: Settings > Database > Connection string (URI mode, port 5432 for direct)
DATABASE_URL=postgresql://postgres:[password]@db.xxxxx.supabase.co:5432/postgres

# CFB Data API — https://collegefootballdata.com/key
CFB_API_KEY=your_cfb_data_api_key
